{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ospex-org/ospex-artifacts/schemas/artifact-index.schema.json",
  "title": "Ospex Artifact Index",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "generatedAt", "repository", "artifacts", "latest"],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://github.com/ospex-org/ospex-artifacts/schemas/artifact-index.schema.json"
    },
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "repository": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["artifactType", "artifactId", "status", "summaryPath", "dataPath"],
        "properties": {
          "artifactType": {
            "type": "string",
            "enum": ["run", "release-acceptance", "daily-digest"]
          },
          "artifactId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "description": "Artifact-level controlled vocabulary; see docs/artifact-types.md. Gate-level statuses such as pass/not_run are separate."
          },
          "network": {
            "type": ["string", "null"]
          },
          "date": {
            "type": ["string", "null"],
            "format": "date"
          },
          "summaryPath": {
            "type": "string"
          },
          "dataPath": {
            "type": "string"
          },
          "rawPath": {
            "type": ["string", "null"]
          }
        },
        "allOf": [
          {
            "if": {
              "properties": { "artifactType": { "const": "run" } },
              "required": ["artifactType"]
            },
            "then": {
              "properties": {
                "status": {
                  "enum": ["complete_verified", "complete_verified_with_caveats", "partial", "superseded"]
                }
              }
            }
          },
          {
            "if": {
              "properties": { "artifactType": { "const": "release-acceptance" } },
              "required": ["artifactType"]
            },
            "then": {
              "properties": {
                "status": {
                  "enum": ["stage0_green", "stage0_green_with_caveats", "stage0_partial", "stage0_failed", "superseded"]
                }
              }
            }
          },
          {
            "if": {
              "properties": { "artifactType": { "const": "daily-digest" } },
              "required": ["artifactType"]
            },
            "then": {
              "properties": {
                "status": {
                  "enum": ["complete", "complete_with_caveats", "partial", "superseded"]
                }
              }
            }
          }
        ]
      }
    },
    "latest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runs", "releases", "daily"],
      "properties": {
        "runs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "releases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "daily": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
