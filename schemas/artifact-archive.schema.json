{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ospex-org/ospex-artifacts/schemas/artifact-archive.schema.json",
  "title": "Ospex Artifact Archive Index",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "generatedAt", "repository", "archive", "artifacts"],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://github.com/ospex-org/ospex-artifacts/schemas/artifact-archive.schema.json"
    },
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "repository": {
      "type": "string",
      "const": "ospex-org/ospex-artifacts"
    },
    "archive": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "year"],
      "properties": {
        "scope": {
          "type": "string",
          "const": "year"
        },
        "year": {
          "type": "integer",
          "minimum": 2000,
          "maximum": 3000
        }
      }
    },
    "artifacts": {
      "type": "array",
      "description": "Full archive entries for this archive scope, sorted by publishedAt descending.",
      "items": { "$ref": "#/$defs/artifactEntry" }
    }
  },
  "$defs": {
    "artifactEntry": {
      "type": "object",
      "additionalProperties": true,
      "required": ["artifactType", "artifactId", "status", "publishedAt", "summaryPath", "dataPath"],
      "properties": {
        "artifactType": {
          "type": "string",
          "enum": ["run", "release-acceptance", "daily-digest"]
        },
        "artifactId": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "description": "Artifact-level controlled vocabulary; see docs/artifact-types.md. Gate-level statuses such as pass/not_run are separate."
        },
        "publishedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Sortable publication timestamp for feed ordering. Do not derive feed order from artifactId or date."
        },
        "network": {
          "type": ["string", "null"]
        },
        "date": {
          "type": ["string", "null"],
          "format": "date",
          "description": "Subject calendar date, which may differ from publication time."
        },
        "summaryPath": {
          "type": "string"
        },
        "dataPath": {
          "type": "string"
        },
        "rawPath": {
          "type": ["string", "null"]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "artifactType": { "const": "run" } },
            "required": ["artifactType"]
          },
          "then": {
            "properties": {
              "status": {
                "enum": ["complete_verified", "complete_verified_with_caveats", "partial", "superseded"]
              }
            }
          }
        },
        {
          "if": {
            "properties": { "artifactType": { "const": "release-acceptance" } },
            "required": ["artifactType"]
          },
          "then": {
            "properties": {
              "status": {
                "enum": ["stage0_green", "stage0_green_with_caveats", "stage0_partial", "stage0_failed", "superseded"]
              }
            }
          }
        },
        {
          "if": {
            "properties": { "artifactType": { "const": "daily-digest" } },
            "required": ["artifactType"]
          },
          "then": {
            "properties": {
              "status": {
                "enum": ["complete", "complete_with_caveats", "partial", "superseded"]
              }
            }
          }
        }
      ]
    }
  }
}
